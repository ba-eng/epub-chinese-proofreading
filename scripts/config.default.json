{
  "_description": "EPUB 中文校对默认配置。可复制到工作目录作为 config.json 覆盖。",

  "blacklist": [
    "心头一颤",
    "美眸",
    "红唇",
    "绝美",
    "倾城",
    "江湖",
    "京城",
    "门派",
    "内力",
    "娇躯",
    "眸子",
    "俊脸",
    "冷哼",
    "嗤笑",
    "话音刚落",
    "目光如炬",
    "双眸",
    "凤眸",
    "星眸",
    "玉手",
    "纤手",
    "不由自主",
    "情不自禁",
    "心神荡漾",
    "冷一笑",
    "淡淡一笑",
    "轻哼一声",
    "话音未落",
    "此言一出",
    "嘴角微扬",
    "嘴角勾起"
  ],

  "blacklist_advisory": [
    "不禁",
    "不由得",
    "颤抖",
    "心中一动",
    "心头一热"
  ],

  "_blacklist_note": "blacklist_defaults 是机械安全替换（非上下文感知），LLM 在第 1 轮校对时应逐条审视并在 corrections 中覆盖不合适的替换。blacklist_advisory 只提示审视，不计入硬错误、不触发机械替换。",
  "blacklist_defaults": {
    "京城": "都城",
    "眸子": "眼眸",
    "心头一颤": "心中一紧",
    "嗤笑": "冷笑",
    "倾城": "绝色",
    "目光如炬": "目光锐利",
    "绝美": "极美",
    "双眸": "双眼",
    "凤眸": "眼眸",
    "星眸": "眼眸",
    "不由自主": "不由",
    "情不自禁": "忍不住",
    "心神荡漾": "心神动摇",
    "话音未落": "话未说完",
    "此言一出": "此话一出",
    "嘴角微扬": "嘴角上扬",
    "嘴角勾起": "嘴角上扬",
    "娇躯": "身体",
    "冷一笑": "冷笑",
    "淡淡一笑": "微微一笑",
    "轻哼一声": "哼了一声"
  },

  "proofreading": {
    "max_change_ratio": 0.4,
    "long_text_threshold": 300,
    "split_punctuation": ["。", "？", "！"],
    "rules": {
      "naturalize_word_order": true,
      "remove_translation_patterns": true,
      "trim_redundancy": true,
      "minor_restructure": true,
      "normalize_punctuation": true,
      "enforce_glossary": true
    }
  },

  "chapter_batch_size": 5,
  "create_text_backup": true
}
